// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String? // Optional for SSO users
  firstName   String
  lastName    String
  phone       String?
  dateOfBirth DateTime?
  gender      Gender?
  timezone    String    @default("UTC")

  // Authentication
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // SSO
  googleId String?
  appleId  String?

  // Profile
  avatar           String?
  emergencyContact String?

  // Privacy and Consent
  dataProcessingConsent    Boolean   @default(false)
  marketingConsent         Boolean   @default(false)
  analyticsConsent         Boolean   @default(false)
  healthDataSharingConsent Boolean   @default(false)
  consentVersion           String? // Track consent version for compliance
  consentDate              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  healthRecords        HealthRecord[]
  healthMetrics        HealthMetrics[]
  healthDataSync       HealthDataSync[]
  healthDataConsent    HealthDataConsent[]
  healthDataAccess     HealthDataAccess[]
  dataExportRequests   DataExportRequest[]
  dataDeletionRequests DataDeletionRequest[]
  prescriptions        Prescription[]
  careGroupMembers     CareGroupMember[]
  notifications        Notification[]
  checkIns             DailyCheckIn[]
  documents            Document[]

  @@map("users")
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// Health Data Integration
model HealthRecord {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Health metrics
  dataType   HealthDataType
  value      Float
  unit       String
  recordedAt DateTime
  source     DataSource

  // Metadata
  deviceId   String?
  confidence Float?
  notes      String?

  // Time-series optimization
  year  Int // For partitioning
  month Int // For partitioning
  day   Int // For efficient queries

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, dataType, recordedAt])
  @@index([userId, year, month])
  @@index([recordedAt])
  @@map("health_records")
}

// Enhanced health data model for comprehensive tracking
model HealthMetrics {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  // Activity metrics
  steps           Int?
  distance        Float? // in kilometers
  caloriesBurned  Int?
  activeMinutes   Int?
  exerciseMinutes Int?

  // Vital signs
  heartRateResting Int?
  heartRateMax     Int?
  heartRateAvg     Int?
  bloodPressureSys Int?
  bloodPressureDia Int?
  oxygenSaturation Float?
  bodyTemperature  Float?

  // Sleep data
  sleepDuration     Int? // minutes
  deepSleepDuration Int? // minutes
  remSleepDuration  Int? // minutes
  sleepScore        Int? // 0-100
  bedTime           DateTime?
  wakeTime          DateTime?

  // Body composition
  weight     Float?
  height     Float?
  bmi        Float?
  bodyFat    Float?
  muscleMass Float?

  // Specialized metrics
  bloodGlucose     Float?
  insulinLevel     Float?
  cholesterolTotal Float?
  cholesterolLDL   Float?
  cholesterolHDL   Float?

  // Data sources and sync info
  lastSyncAt  DateTime?
  syncSource  DataSource
  dataQuality DataQuality @default(GOOD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("health_metrics")
}

// Enhanced health data sync tracking
model HealthDataSync {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  source       DataSource
  lastSyncAt   DateTime
  syncStatus   SyncStatus
  recordsCount Int        @default(0)
  errorMessage String?

  // Sync window
  syncFromDate DateTime
  syncToDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, source])
  @@map("health_data_sync")
}

// User consent tracking for health data
model HealthDataConsent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Consent details
  consentType    ConsentType
  dataCategories String[] // Categories of health data
  purpose        String // Purpose of data collection/sharing
  consentGranted Boolean
  consentDate    DateTime
  revokedAt      DateTime?
  consentVersion String // Version of consent terms

  // Legal compliance
  legalBasis      String // Legal basis for processing (GDPR, Vietnam Decree 13/2022)
  retentionPeriod Int? // Days to retain data

  // Care group sharing consent
  careGroupId     String?
  shareWithFamily Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, consentType])
  @@map("health_data_consent")
}

// Health data access audit trail for transparency
model HealthDataAccess {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Access details
  action     String // Action performed (VIEW, EXPORT, DELETE, etc.)
  accessor   String // Who accessed the data (USER, SYSTEM, CAREGIVER, etc.)
  dataType   String? // Type of data accessed
  accessedAt DateTime @default(now())

  // Technical details
  ipAddress String?
  userAgent String?

  // Additional metadata
  metadata String? // JSON string for additional context

  @@index([userId, accessedAt])
  @@map("health_data_access")
}

// Data export requests for user transparency
model DataExportRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  downloadUrl String?
  expiresAt   DateTime?

  // Request metadata
  exportType String  @default("FULL_DATA") // FULL_DATA, HEALTH_ONLY, etc.
  status     String  @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileSize   BigInt?

  @@index([userId, requestedAt])
  @@map("data_export_requests")
}

// Data deletion requests for GDPR/Decree 13/2023 compliance
model DataDeletionRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  requestedAt           DateTime  @default(now())
  scheduledDeletionDate DateTime
  deletedAt             DateTime?
  cancelledAt           DateTime?

  // Request metadata
  status String  @default("PENDING") // PENDING, SCHEDULED, COMPLETED, CANCELLED
  reason String? // Optional reason for deletion

  @@index([userId, requestedAt])
  @@map("data_deletion_requests")
}

enum HealthDataType {
  HEART_RATE
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  WEIGHT
  HEIGHT
  BMI
  BLOOD_GLUCOSE
  STEPS
  SLEEP_HOURS
  EXERCISE_MINUTES
  CALORIES_BURNED
  OXYGEN_SATURATION
  BODY_TEMPERATURE
  DISTANCE
  ACTIVE_MINUTES
  RESTING_HEART_RATE
  MAX_HEART_RATE
  DEEP_SLEEP
  REM_SLEEP
  SLEEP_SCORE
  BODY_FAT
  MUSCLE_MASS
  INSULIN_LEVEL
  CHOLESTEROL_TOTAL
  CHOLESTEROL_LDL
  CHOLESTEROL_HDL
}

enum DataSource {
  MANUAL
  APPLE_HEALTH
  GOOGLE_FIT
  DEVICE_SYNC
  IMPORTED_CSV
  API_INTEGRATION
}

enum DataQuality {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
}

enum ConsentType {
  DATA_COLLECTION
  DATA_SHARING
  FAMILY_SHARING
  ANALYTICS
  MARKETING
  RESEARCH
}

// Prescription Management
model Prescription {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Medication details
  medicationName String
  dosage         String
  frequency      String
  instructions   String?
  startDate      DateTime
  endDate        DateTime?

  // OCR data
  ocrImageUrl   String?
  ocrConfidence Float?
  isVerified    Boolean @default(false)

  // Refill info
  refillsLeft  Int?
  pharmacy     String?
  prescribedBy String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reminders Reminder[]

  @@map("prescriptions")
}

// Notification & Reminder System
model Reminder {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  // Timing
  scheduledAt DateTime
  isRecurring Boolean  @default(true)
  frequency   String? // e.g., "daily", "twice_daily", "weekly"

  // Status
  status         ReminderStatus @default(PENDING)
  sentAt         DateTime?
  acknowledgedAt DateTime?

  // Retry logic
  retryCount Int @default(0)
  maxRetries Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reminders")
}

enum ReminderStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  MISSED
  FAILED
}

// Care Groups & Family Network
model CareGroup {
  id          String  @id @default(uuid())
  name        String
  description String?
  inviteCode  String  @unique

  // Settings
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members CareGroupMember[]

  @@map("care_groups")
}

model CareGroupMember {
  id          String    @id @default(uuid())
  careGroupId String
  careGroup   CareGroup @relation(fields: [careGroupId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role     CareRole @default(MEMBER)
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)

  // Permissions
  canViewHealth     Boolean @default(false)
  canReceiveAlerts  Boolean @default(true)
  canManageSettings Boolean @default(false)

  @@unique([careGroupId, userId])
  @@map("care_group_members")
}

enum CareRole {
  OWNER
  ADMIN
  CAREGIVER
  MEMBER
}

// Daily Check-ins
model DailyCheckIn {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  // Health metrics
  moodScore    Int? @db.SmallInt // 1-10
  energyLevel  Int? @db.SmallInt // 1-10
  sleepQuality Int? @db.SmallInt // 1-10
  painLevel    Int? @db.SmallInt // 0-10
  stressLevel  Int? @db.SmallInt // 1-10

  // Symptoms
  symptoms String[] // Array of symptom strings
  notes    String?

  // AI generated insights
  aiInsights String?
  riskScore  Float?

  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("daily_check_ins")
}

// Notifications
model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  title   String
  message String
  type    NotificationType

  // Delivery
  channel NotificationChannel[]
  sentAt  DateTime?
  readAt  DateTime?

  // Metadata
  actionUrl String?
  priority  NotificationPriority @default(NORMAL)

  // Audit and tracking
  auditLogs NotificationAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

// Notification Audit Logging for delivery tracking
model NotificationAuditLog {
  id             String @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // Event tracking
  event      NotificationEvent
  channel    NotificationChannel
  status     DeliveryStatus
  
  // Delivery details
  deliveryId String? // External delivery ID from push/email/SMS services
  providerId String? // Provider-specific tracking ID
  
  // Error tracking
  errorCode    String?
  errorMessage String?
  
  // Performance metrics
  processingTime Int? // Time in milliseconds
  retryCount     Int  @default(0)
  
  // Metadata
  metadata Json? // Additional context (IP, user agent, etc.)
  
  createdAt DateTime @default(now())
  
  @@map("notification_audit_logs")
}

// Notification Delivery Tracking
model NotificationDeliveryLog {
  id             String @id @default(uuid())
  notificationId String
  
  // Delivery details
  channel        NotificationChannel
  deliveryStatus DeliveryStatus
  deliveryTime   DateTime?
  
  // External service tracking
  externalId     String? // FCM message ID, email ID, etc.
  providerName   String? // 'FCM', 'SendGrid', 'Twilio', etc.
  
  // Engagement tracking
  openedAt   DateTime?
  clickedAt  DateTime?
  
  // Error details
  errorCode    String?
  errorMessage String?
  
  // Performance
  latency Int? // Time from queue to delivery (ms)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("notification_delivery_logs")
}

// Notification Templates for personalization
model NotificationTemplate {
  id     String @id @default(uuid())
  
  // Template identification
  name        String @unique
  description String?
  type        NotificationType
  
  // Template content with placeholders
  titleTemplate   String  // e.g., "Hello {{userName}}, time for your {{medicationName}}"
  messageTemplate String  // e.g., "Take {{dosage}} of {{medicationName}} at {{time}}"
  
  // Template metadata
  placeholders Json    // Array of placeholder definitions with types and validation
  isActive     Boolean @default(true)
  version      Int     @default(1)
  
  // Personalization options
  channels         NotificationChannel[]
  defaultPriority  NotificationPriority @default(NORMAL)
  
  // Localization support
  language String @default("en")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("notification_templates")
}

// Document Management
model Document {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // File info
  fileName String
  fileUrl  String
  fileType String
  fileSize Int

  // Metadata
  title       String?
  description String?
  category    DocumentCategory?
  tags        String[]

  // AI processing
  extractedText String?
  aiSummary     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

enum DocumentCategory {
  PRESCRIPTION
  MEDICAL_RECORD
  INSURANCE
  REPORT
  OTHER
}

enum NotificationType {
  MEDICATION_REMINDER
  HEALTH_ALERT
  CHECK_IN_REMINDER
  CARE_GROUP_UPDATE
  SYSTEM_NOTIFICATION
  AI_INSIGHT
}

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationEvent {
  CREATED
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  RETRIED
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  OPENED
  CLICKED
  UNSUBSCRIBED
}
