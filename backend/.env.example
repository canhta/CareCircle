# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/carecircle"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USERNAME="postgres"
DATABASE_PASSWORD="password"
DATABASE_NAME="carecircle"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# Server Configuration
PORT=3000
NODE_ENV="development"

# External API Keys
APPLE_HEALTHKIT_KEY="your-apple-healthkit-key"
GOOGLE_FIT_CLIENT_ID="your-google-fit-client-id"
GOOGLE_FIT_CLIENT_SECRET="your-google-fit-client-secret"

# AI Services
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4"

# OCR Services
GOOGLE_VISION_API_KEY="your-google-vision-api-key"

# Push Notifications
FCM_SERVER_KEY="your-fcm-server-key"
APNS_KEY_ID="your-apns-key-id"
APNS_TEAM_ID="your-apns-team-id"

# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="carecircle-storage"
AWS_REGION="us-east-1"

# Payment Integration (for Vietnam market)
MOMO_PARTNER_CODE="your-momo-partner-code"
MOMO_ACCESS_KEY="your-momo-access-key"
MOMO_SECRET_KEY="your-momo-secret-key"
ZALOPAY_APP_ID="your-zalopay-app-id"
ZALOPAY_KEY1="your-zalopay-key1"
ZALOPAY_KEY2="your-zalopay-key2"

# Monitoring and Logging
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"
