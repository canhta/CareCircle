# Flutter Environment Configuration
# This file should be copied to .env and configured with actual values

# API Configuration
API_BASE_URL=http://localhost:3000
API_TIMEOUT=30000

# Platform specific configurations
IOS_BUNDLE_ID=com.carecircle.app
ANDROID_PACKAGE_NAME=com.carecircle.app

# Feature Flags
ENABLE_HEALTHKIT=true
ENABLE_GOOGLE_FIT=true
ENABLE_OCR_SCANNING=true
ENABLE_AI_INSIGHTS=true

# Development/Debug
DEBUG_MODE=true
LOG_LEVEL=debug

# App Store / Play Store
APP_VERSION=1.0.0
BUILD_NUMBER=1
